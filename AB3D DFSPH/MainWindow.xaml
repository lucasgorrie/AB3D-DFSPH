<Window x:Class="AB3D_DFSPH.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AB3D_DFSPH"
        mc:Ignorable="d"
        xmlns:controls="clr-namespace:Ab3d.Controls;assembly=Ab3d.PowerToys"  
        xmlns:dxControls="clr-namespace:Ab3d.DirectX.Controls;assembly=Ab3d.DXEngine.Wpf"
        xmlns:cameras="clr-namespace:Ab3d.Cameras;assembly=Ab3d.PowerToys"
        Title="MainWindow" Height="450" Width="800">
    
    <Grid x:Name="ViewportGrid">

        <dxControls:DXViewportView x:Name="DirectXViewportView" PresentationType="DirectXOverlay">
            <Viewport3D x:Name="Viewport">
                
            </Viewport3D>
        </dxControls:DXViewportView>

        <cameras:TargetPositionCamera x:Name="Camera" TargetViewport3D="{Binding ElementName=Viewport}" Distance="10"/>

        <controls:MouseCameraController Name="MouseCameraController" RotateCameraConditions="LeftMouseButtonPressed" TargetCamera="{Binding ElementName=Camera}"
                                        MoveCameraConditions="LeftMouseButtonPressed, ControlKey" EventsSourceElement="{Binding ElementName=ViewportGrid}"/>

    </Grid>
    
</Window>
